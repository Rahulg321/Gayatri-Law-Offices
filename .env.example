# Better Auth (required for admin login)
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=generate_with_bunx_better_auth_cli_secret

# Google OAuth (admin sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist for admin dashboard
ADMIN_EMAILS=you@example.com,other@example.com

# Drizzle Studio + Drizzle Kit remote D1 (required for `bun run db:studio`)
# Create token: https://dash.cloudflare.com/profile/api-tokens (D1 Read is enough)
# Use DRIZZLE_CLOUDFLARE_API_TOKEN so Wrangler dev does not pick up a D1-only token
# (CLOUDFLARE_API_TOKEN in .env.local breaks remote dev with auth error 10000).
CLOUDFLARE_ACCOUNT_ID=
DRIZZLE_CLOUDFLARE_API_TOKEN=
# Optional legacy name (also read by drizzle.config.ts):
# CLOUDFLARE_API_TOKEN=
# Optional — defaults to database_id in wrangler.jsonc
# D1_DATABASE_ID=f72eac8b-bb8c-4657-920a-87ee3fd100e4

# Use local Miniflare D1 file instead of remote (usually empty when remote: true in wrangler)
# DRIZZLE_STUDIO_TARGET=local

# R2 public URL (optional if set in wrangler.jsonc `vars.R2_PUBLIC_BASE_URL`)
# Must match the custom domain that serves `gayatri-law-offices-assets`.
R2_PUBLIC_BASE_URL=https://cdn.gayatrilawoffices.in
